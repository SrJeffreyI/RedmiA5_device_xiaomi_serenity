<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">

    <!-- Screen brightness controls -->
    <integer name="config_screenBrightnessSettingMinimum">1</integer>
    <integer name="config_screenBrightnessSettingMaximum">255</integer>
    <integer name="config_screenBrightnessSettingDefault">102</integer>

    <!-- Is the device capable of hot swappable antennas -->
    <bool name="config_antenna_hot_swapping">false</bool>

    <!-- Whether a software navigation bar should be shown -->
    <bool name="config_showNavigationBar">true</bool>

    <!-- Flag indicating whether the we should enable the automatic brightness in config.xml -->
    <bool name="config_automatic_brightness_available">true</bool>

    <!-- Boolean indicating if the light sensor is used to control the keyboard backlight -->
    <bool name="config_allowAutoBrightnessWhileDozing">true</bool>

</resources>
